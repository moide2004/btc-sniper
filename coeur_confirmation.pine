//@version=5
// =============================================================================
//  CŒUR — CONFIRMATION : Coinbase Premium + Divergences RSI (1W / 2W / 1M)
// -----------------------------------------------------------------------------
//  Outil de CONFIRMATION (pas le cœur du systeme). A utiliser de preference sur
//  un graphe BTC. Tout est reglable dans les "Settings" de l'indicateur.
//
//  - Coinbase Premium : ecart de prix Coinbase (BTC-USD) vs Binance (BTC-USDT).
//      premium > 0 = la demande US/institutionnelle pousse -> penche ACHAT.
//      premium < 0 = penche VENTE.
//  - RSI + divergences regulieres, sur le graphe ET en 1W / 2W / 1M.
//  - Confirmation BUY / SELL seulement quand premium ET divergence HTF s'alignent.
//
//  NB : Pine Script n'a PAS acces au carnet d'ordres (murs/absorption/spoof) :
//  ca, ca reste dans le bot serveur. Ici, c'est de la confirmation prix.
// =============================================================================
indicator("Cœur — Confirmation : Coinbase Premium + RSI Div (1W/2W/1M)",
     shorttitle="CB Prem + RSI Div", overlay=false)

// ------------------------------- RÉGLAGES ------------------------------------
gP = "Coinbase Premium (demande US / institutionnelle)"
cbSym  = input.symbol("COINBASE:BTCUSD", "Symbole Coinbase", group=gP)
bnSym  = input.symbol("BINANCE:BTCUSDT", "Symbole Binance",  group=gP)
premLen = input.int(7, "Lissage du premium (EMA)", minval=1, group=gP)

gR = "RSI & Divergences"
rsiLen = input.int(14, "Longueur RSI", minval=2, group=gR)
obLvl  = input.int(70, "Niveau surachat", group=gR)
osLvl  = input.int(30, "Niveau survente", group=gR)
lbL    = input.int(5, "Pivot gauche (barres)",  minval=1, group=gR)
lbR    = input.int(5, "Pivot droite (barres)",  minval=1, group=gR)
showDiv = input.bool(true, "Marquer les divergences du graphe", group=gR)

gT = "Confirmation multi-timeframe"
useW  = input.bool(true, "Tenir compte du 1W", group=gT)
use2W = input.bool(true, "Tenir compte du 2W", group=gT)
useM  = input.bool(true, "Tenir compte du 1M", group=gT)

// --------------------------- COINBASE PREMIUM --------------------------------
cb = request.security(cbSym, timeframe.period, close)
bn = request.security(bnSym, timeframe.period, close)
premPct = bn != 0 ? (cb - bn) / bn * 100.0 : na
premEma = ta.ema(premPct, premLen)
premUp  = premEma > premEma[1]

// ------------------- RSI + DIVERGENCES (fonction reutilisable) ---------------
// Renvoie [rsi, divergence_haussiere, divergence_baissiere] pour le contexte
// dans lequel elle est evaluee (graphe courant OU timeframe demande).
f_sig() =>
    r = ta.rsi(close, rsiLen)
    plF = not na(ta.pivotlow(r, lbL, lbR))    // creux de RSI confirme
    phF = not na(ta.pivothigh(r, lbL, lbR))   // sommet de RSI confirme
    // Divergence HAUSSIERE : prix fait un plus-bas plus bas, RSI un plus-bas plus haut
    rHL  = plF and r[lbR]   > ta.valuewhen(plF, r[lbR], 1)
    pLL  = plF and low[lbR] < ta.valuewhen(plF, low[lbR], 1)
    bull = rHL and pLL
    // Divergence BAISSIERE : prix fait un plus-haut plus haut, RSI un plus-haut plus bas
    rLH  = phF and r[lbR]    < ta.valuewhen(phF, r[lbR], 1)
    pHH  = phF and high[lbR] > ta.valuewhen(phF, high[lbR], 1)
    bear = rLH and pHH
    [r, bull, bear]

// Timeframe du graphe
[rsiC, bullC, bearC] = f_sig()

// Hautes timeframes (1W / 2W / 1M)
[rW,  bullW,  bearW]  = request.security(syminfo.tickerid, "W",  f_sig(), lookahead=barmerge.lookahead_off)
[r2W, bull2W, bear2W] = request.security(syminfo.tickerid, "2W", f_sig(), lookahead=barmerge.lookahead_off)
[rM,  bullM,  bearM]  = request.security(syminfo.tickerid, "M",  f_sig(), lookahead=barmerge.lookahead_off)

// ------------------------------ AFFICHAGE ------------------------------------
plot(rsiC, "RSI", color=color.new(#b58bff, 0), linewidth=2)
hline(obLvl, "Surachat", color=color.new(color.red, 60))
hline(50,    "Milieu",   color=color.new(color.gray, 75))
hline(osLvl, "Survente", color=color.new(color.green, 60))

plotshape(showDiv and bullC, title="Div. haussiere (graphe)", style=shape.triangleup,
     location=location.bottom, color=color.lime, size=size.tiny, offset=-lbR)
plotshape(showDiv and bearC, title="Div. baissiere (graphe)", style=shape.triangledown,
     location=location.top, color=color.red, size=size.tiny, offset=-lbR)

// --------------------------- CONFIRMATION ------------------------------------
htfBull = (useW and bullW) or (use2W and bull2W) or (useM and bullM)
htfBear = (useW and bearW) or (use2W and bear2W) or (useM and bearM)
confBull = premEma > 0 and htfBull   // premium positif + divergence haussiere HTF
confBear = premEma < 0 and htfBear   // premium negatif + divergence baissiere HTF

plotshape(confBull and not confBull[1], title="CONFIRMATION ACHAT", style=shape.labelup,
     location=location.bottom, color=color.green, textcolor=color.white, text="BUY", size=size.small)
plotshape(confBear and not confBear[1], title="CONFIRMATION VENTE", style=shape.labeldown,
     location=location.top, color=color.red, textcolor=color.white, text="SELL", size=size.small)

alertcondition(confBull and not confBull[1], "Confirmation ACHAT",
     "Coinbase premium positif + divergence RSI HTF : confirmation HAUSSIERE")
alertcondition(confBear and not confBear[1], "Confirmation VENTE",
     "Coinbase premium negatif + divergence RSI HTF : confirmation BAISSIERE")

// ------------------------------- TABLEAU -------------------------------------
f_stat(r) => r >= obLvl ? "surachat" : r <= osLvl ? "survente" : "neutre"
f_col(r)  => r >= obLvl ? color.new(color.red, 65) : r <= osLvl ? color.new(color.green, 65) : color.new(color.gray, 82)
f_div(b, s) => b ? "▲ haussiere" : s ? "▼ baissiere" : "–"

var table t = table.new(position.top_right, 2, 7, border_width=1, frame_color=color.new(color.gray, 50), frame_width=1)
if barstate.islast
    regime = confBull ? "HAUSSIÈRE" : confBear ? "BAISSIÈRE" : "NEUTRE"
    rcol   = confBull ? color.green : confBear ? color.red : color.gray
    table.cell(t, 0, 0, "CONFIRMATION", text_color=color.white, bgcolor=color.new(color.gray, 25))
    table.cell(t, 1, 0, regime, text_color=color.white, bgcolor=color.new(rcol, 25))
    table.cell(t, 0, 1, "Coinbase Premium", text_color=color.white)
    table.cell(t, 1, 1, str.tostring(premEma, "0.00") + "%  " + (premUp ? "↑" : "↓"),
         text_color = premEma >= 0 ? color.green : color.red)
    table.cell(t, 0, 2, "RSI (graphe)", text_color=color.white)
    table.cell(t, 1, 2, str.tostring(rsiC, "0") + " · " + f_stat(rsiC), bgcolor=f_col(rsiC), text_color=color.white)
    table.cell(t, 0, 3, "RSI 1W", text_color=color.white)
    table.cell(t, 1, 3, str.tostring(rW, "0") + " · " + f_div(bullW, bearW), bgcolor=f_col(rW), text_color=color.white)
    table.cell(t, 0, 4, "RSI 2W", text_color=color.white)
    table.cell(t, 1, 4, str.tostring(r2W, "0") + " · " + f_div(bull2W, bear2W), bgcolor=f_col(r2W), text_color=color.white)
    table.cell(t, 0, 5, "RSI 1M", text_color=color.white)
    table.cell(t, 1, 5, str.tostring(rM, "0") + " · " + f_div(bullM, bearM), bgcolor=f_col(rM), text_color=color.white)
    table.cell(t, 0, 6, "Premium > 0 ?", text_color=color.white)
    table.cell(t, 1, 6, premEma > 0 ? "oui (achat US)" : "non", text_color = premEma > 0 ? color.green : color.red)

//@version=5
// =============================================================================
//  TRIPLE DIVERGENCE / THREE DRIVES + CHANDELIERS — version 100% sans indentation
//  (aucun bloc 'if', aucune fonction multi-lignes -> rien ne casse au coller).
//  Overlay. Divergence calculee sur le timeframe affiche. Scalp comme swing.
//  NB : pas de liquidations (inaccessibles a un indicateur TradingView).
// =============================================================================
indicator("Triple Div / Three Drives + Chandeliers [calibré]", shorttitle="3Drives+Bougies", overlay=true, max_labels_count=500)

// ------------------------------- RÉGLAGES ------------------------------------
gD = "Divergence / Three Drives"
rsiLen     = input.int(14, "Longueur RSI", minval=2, group=gD)
lbL        = input.int(5,  "Pivot gauche (barres)",  minval=1, group=gD)
lbR        = input.int(5,  "Pivot droite (barres)",  minval=1, group=gD)
divMin     = input.int(5,  "Distance min entre pivots (barres)", minval=1, group=gD)
divMax     = input.int(60, "Distance max entre pivots (barres)", minval=2, group=gD)
drives     = input.int(3,  "Poussées pour le signal fort (triple = 3)", minval=2, maxval=6, group=gD)
drvWin     = input.int(150,"Fenêtre max des poussées (barres)", minval=10, group=gD)
useOBOS    = input.bool(true, "Filtre RSI survente/surachat", group=gD)
osLvl      = input.int(40, "Seuil survente (div. haussière)", group=gD)
obLvl      = input.int(60, "Seuil surachat (div. baissière)", group=gD)
onlyTriple = input.bool(false, "Afficher SEULEMENT le signal triple", group=gD)

gC = "Chandeliers (filtrés par ATR)"
atrLen     = input.int(14, "Longueur ATR", minval=1, group=gC)
minBodyATR = input.float(0.6, "Corps min (x ATR)", minval=0.0, step=0.1, group=gC)
useEngulf  = input.bool(true,  "Avalement (engulfing)", group=gC)
engulfMin  = input.float(0.8, "Avalement: corps min (x ATR)", minval=0.0, step=0.1, group=gC)
useVol     = input.bool(true,  "Avalement: confirmer par le volume", group=gC)
volLen     = input.int(20, "Volume: moyenne (barres)", minval=1, group=gC)
volMult    = input.float(1.5, "Volume: x la moyenne pour valider", minval=0.1, step=0.1, group=gC)
usePin     = input.bool(true,  "Marteau / Étoile filante", group=gC)
pinRatio   = input.float(2.0,  "Mèche / corps min (pin bar)", minval=1.0, step=0.1, group=gC)
pinCtx     = input.int(10, "Fenêtre extrême local (pin bar)", minval=1, group=gC)

gI = "Affichage"
showPanel  = input.bool(true, "Tableau d'état", group=gI)

confirmed = barstate.isconfirmed
atr = ta.atr(atrLen)

// --------------------------- RSI + DIVERGENCES -------------------------------
r = ta.rsi(close, rsiLen)
plF = not na(ta.pivotlow(r, lbL, lbR))
phF = not na(ta.pivothigh(r, lbL, lbR))
prevRSIlow  = ta.valuewhen(plF, r[lbR], 1)
prevLow     = ta.valuewhen(plF, low[lbR], 1)
prevRSIhigh = ta.valuewhen(phF, r[lbR], 1)
prevHigh    = ta.valuewhen(phF, high[lbR], 1)
gapBull = ta.barssince(plF[1])
gapBear = ta.barssince(phF[1])
bullDiv = plF and r[lbR] > prevRSIlow and low[lbR] < prevLow and gapBull >= divMin and gapBull <= divMax and (not useOBOS or prevRSIlow <= osLvl)
bearDiv = phF and r[lbR] < prevRSIhigh and high[lbR] > prevHigh and gapBear >= divMin and gapBear <= divMax and (not useOBOS or prevRSIhigh >= obLvl)

// ------------------ COMPTEUR DE POUSSÉES (sans bloc 'if') --------------------
var int bullDrives = 0
var int bearDrives = 0
var int lastBullBar = na
var int lastBearBar = na
gapOkBull = not na(lastBullBar) and (bar_index - lastBullBar) <= drvWin
gapOkBear = not na(lastBearBar) and (bar_index - lastBearBar) <= drvWin
newBull = bullDiv ? (gapOkBull ? bullDrives + 1 : 1) : bullDrives
newBear = bearDiv ? (gapOkBear ? bearDrives + 1 : 1) : bearDrives
tripleBuy  = bullDiv and newBull >= drives
tripleSell = bearDiv and newBear >= drives
bullDrives := tripleBuy ? 0 : (bearDiv ? 0 : newBull)
bearDrives := tripleSell ? 0 : (bullDiv ? 0 : newBear)
lastBullBar := bullDiv ? bar_index : lastBullBar
lastBearBar := bearDiv ? bar_index : lastBearBar

// --------------------------- MARQUEURS DIVERGENCE ----------------------------
minorBull = bullDiv and not tripleBuy and not onlyTriple
minorBear = bearDiv and not tripleSell and not onlyTriple
plotshape(minorBull, title="Divergence haussière", style=shape.triangleup, location=location.belowbar, color=color.new(color.green, 0), size=size.tiny)
plotshape(minorBear, title="Divergence baissière", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), size=size.tiny)
plotshape(tripleBuy,  title="TRIPLE BUY",  style=shape.labelup,   location=location.belowbar, color=color.lime, text="BUY",  textcolor=color.black, size=size.normal)
plotshape(tripleSell, title="TRIPLE SELL", style=shape.labeldown, location=location.abovebar, color=color.red,  text="SELL", textcolor=color.white, size=size.normal)

// ------------------------------ CHANDELIERS ----------------------------------
body   = math.abs(close - open)
bodyHi = math.max(open, close)
bodyLo = math.min(open, close)
upWick = high - bodyHi
dnWick = bodyLo - low
signif = body >= atr * minBodyATR
volOK = not useVol or volume > ta.sma(volume, volLen) * volMult
bullEngulf = useEngulf and confirmed and close > open and close[1] < open[1] and close > high[1] and body > atr * engulfMin and low <= ta.lowest(low, pinCtx) and volOK
bearEngulf = useEngulf and confirmed and close < open and close[1] > open[1] and close < low[1] and body > atr * engulfMin and high >= ta.highest(high, pinCtx) and volOK
plotshape(bullEngulf, title="Avalement haussier", style=shape.labelup,   location=location.belowbar, color=color.new(color.green, 0), text="ENG", textcolor=color.white, size=size.tiny)
plotshape(bearEngulf, title="Avalement baissier", style=shape.labeldown, location=location.abovebar, color=color.new(color.red, 0),   text="ENG", textcolor=color.white, size=size.tiny)

atLow  = low  <= ta.lowest(low,  pinCtx)
atHigh = high >= ta.highest(high, pinCtx)
hammer = usePin and confirmed and (high - low) >= atr and dnWick > body * pinRatio and upWick < body and atLow
star   = usePin and confirmed and (high - low) >= atr and upWick > body * pinRatio and dnWick < body and atHigh
plotshape(hammer, title="Marteau", style=shape.triangleup, location=location.belowbar, color=color.new(color.teal, 0), size=size.tiny)
plotshape(star,   title="Étoile filante", style=shape.triangledown, location=location.abovebar, color=color.new(color.orange, 0), size=size.tiny)


// ------------------------ TABLEAU (sans bloc 'if') ---------------------------
bias = bullDrives > bearDrives ? "Haussier" : bearDrives > bullDrives ? "Baissier" : "Neutre"
bcol = bullDrives > bearDrives ? color.green : bearDrives > bullDrives ? color.red : color.gray
rcol = r >= obLvl ? color.red : r <= osLvl ? color.green : color.white
var table t = table.new(position.top_right, 2, 4, border_width=1, frame_color=color.new(color.gray, 50), frame_width=1)
tShow = showPanel and barstate.islast
table.cell(t, 0, 0, tShow ? "RSI" : "", text_color=color.white, bgcolor=tShow ? color.new(color.gray, 30) : color.new(color.gray, 100))
table.cell(t, 1, 0, tShow ? str.tostring(r, "0") : "", text_color=rcol)
table.cell(t, 0, 1, tShow ? "Poussées haussières" : "", text_color=color.white)
table.cell(t, 1, 1, tShow ? str.tostring(bullDrives) + " / " + str.tostring(drives) : "", text_color=color.green)
table.cell(t, 0, 2, tShow ? "Poussées baissières" : "", text_color=color.white)
table.cell(t, 1, 2, tShow ? str.tostring(bearDrives) + " / " + str.tostring(drives) : "", text_color=color.red)
table.cell(t, 0, 3, tShow ? "Biais" : "", text_color=color.white)
table.cell(t, 1, 3, tShow ? bias : "", text_color=color.white, bgcolor=tShow ? color.new(bcol, 40) : color.new(color.gray, 100))

// -------------------------------- ALERTES ------------------------------------
alertcondition(tripleBuy,  "Triple divergence BUY",  "TRIPLE divergence haussiere confirmee")
alertcondition(tripleSell, "Triple divergence SELL", "TRIPLE divergence baissiere confirmee")
alertcondition(bullDiv,    "Divergence haussière",   "Divergence RSI haussiere")
alertcondition(bearDiv,    "Divergence baissière",   "Divergence RSI baissiere")
alertcondition(bullEngulf, "Avalement haussier",     "Bullish engulfing")
alertcondition(bearEngulf, "Avalement baissier",     "Bearish engulfing")
alertcondition(hammer,     "Marteau",                "Marteau a un creux local")
alertcondition(star,       "Étoile filante",         "Etoile filante a un sommet local")

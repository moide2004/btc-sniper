//@version=5
// =============================================================================
//  TRIPLE DIVERGENCE / THREE DRIVES + SIGNAL BOUGIE REGROUPE
//  100% sans indentation (aucun 'if', aucune fonction multi-lignes).
//  - Divergence RSI<->prix (poussees, signal fort a la 3e).
//  - UN SEUL signal bougie directionnel (haussier/baissier) qui regroupe :
//    extreme local + cloture decisive + amplitude (ATR) + volume + RSI extreme.
//  NB : pas de liquidations (inaccessibles a un indicateur TradingView).
// =============================================================================
indicator("Triple Div + Signal Bougie [précis]", shorttitle="3Drives+Bougie", overlay=true, max_labels_count=500)

// ------------------------------- RÉGLAGES ------------------------------------
gD = "Divergence / Three Drives"
rsiLen     = input.int(14, "Longueur RSI", minval=2, group=gD)
lbL        = input.int(5,  "Pivot gauche (barres)",  minval=1, group=gD)
lbR        = input.int(5,  "Pivot droite (barres)",  minval=1, group=gD)
divMin     = input.int(5,  "Distance min entre pivots (barres)", minval=1, group=gD)
divMax     = input.int(60, "Distance max entre pivots (barres)", minval=2, group=gD)
drives     = input.int(3,  "Poussées pour le signal fort (triple = 3)", minval=2, maxval=6, group=gD)
drvWin     = input.int(150,"Fenêtre max des poussées (barres)", minval=10, group=gD)
useOBOS    = input.bool(true, "Filtre RSI survente/surachat", group=gD)
osLvl      = input.int(40, "Seuil survente", group=gD)
obLvl      = input.int(60, "Seuil surachat", group=gD)
onlyTriple = input.bool(false, "Divergence: afficher SEULEMENT le triple", group=gD)

gB = "Signal bougie (regroupé en UN signal)"
useCandle  = input.bool(true,  "Activer le signal bougie", group=gB)
atrLen     = input.int(14, "Longueur ATR", minval=1, group=gB)
candleCtx  = input.int(10, "Fenêtre extrême local (barres)", minval=1, group=gB)
closePos   = input.float(0.66, "Clôture dans le X haut/bas de la bougie", minval=0.5, maxval=1.0, step=0.01, group=gB)
rangeATR   = input.float(1.0, "Amplitude min de la bougie (x ATR)", minval=0.1, step=0.1, group=gB)
candleVol  = input.bool(true,  "Confirmer par le volume", group=gB)
volLen     = input.int(20, "Volume: moyenne (barres)", minval=1, group=gB)
volMult    = input.float(1.5, "Volume: x la moyenne", minval=0.1, step=0.1, group=gB)
candleRsi  = input.bool(true,  "Confirmer par le RSI extrême", group=gB)

gI = "Affichage"
showPanel  = input.bool(true, "Tableau d'état", group=gI)

confirmed = barstate.isconfirmed
atr = ta.atr(atrLen)
r = ta.rsi(close, rsiLen)

// --------------------------- DIVERGENCES (Three Drives) ----------------------
plF = not na(ta.pivotlow(r, lbL, lbR))
phF = not na(ta.pivothigh(r, lbL, lbR))
prevRSIlow  = ta.valuewhen(plF, r[lbR], 1)
prevLow     = ta.valuewhen(plF, low[lbR], 1)
prevRSIhigh = ta.valuewhen(phF, r[lbR], 1)
prevHigh    = ta.valuewhen(phF, high[lbR], 1)
gapBull = ta.barssince(plF[1])
gapBear = ta.barssince(phF[1])
bullDiv = plF and r[lbR] > prevRSIlow and low[lbR] < prevLow and gapBull >= divMin and gapBull <= divMax and (not useOBOS or prevRSIlow <= osLvl)
bearDiv = phF and r[lbR] < prevRSIhigh and high[lbR] > prevHigh and gapBear >= divMin and gapBear <= divMax and (not useOBOS or prevRSIhigh >= obLvl)

var int bullDrives = 0
var int bearDrives = 0
var int lastBullBar = na
var int lastBearBar = na
gapOkBull = not na(lastBullBar) and (bar_index - lastBullBar) <= drvWin
gapOkBear = not na(lastBearBar) and (bar_index - lastBearBar) <= drvWin
newBull = bullDiv ? (gapOkBull ? bullDrives + 1 : 1) : bullDrives
newBear = bearDiv ? (gapOkBear ? bearDrives + 1 : 1) : bearDrives
tripleBuy  = bullDiv and newBull >= drives
tripleSell = bearDiv and newBear >= drives
bullDrives := tripleBuy ? 0 : (bearDiv ? 0 : newBull)
bearDrives := tripleSell ? 0 : (bullDiv ? 0 : newBear)
lastBullBar := bullDiv ? bar_index : lastBullBar
lastBearBar := bearDiv ? bar_index : lastBearBar

minorBull = bullDiv and not tripleBuy and not onlyTriple
minorBear = bearDiv and not tripleSell and not onlyTriple
plotshape(minorBull, title="Divergence haussière", style=shape.triangleup, location=location.belowbar, color=color.new(color.green, 50), size=size.tiny)
plotshape(minorBear, title="Divergence baissière", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 50), size=size.tiny)
plotshape(tripleBuy,  title="TRIPLE BUY",  style=shape.labelup,   location=location.belowbar, color=color.lime, text="BUY",  textcolor=color.black, size=size.normal)
plotshape(tripleSell, title="TRIPLE SELL", style=shape.labeldown, location=location.abovebar, color=color.red,  text="SELL", textcolor=color.white, size=size.normal)

// ------------------- SIGNAL BOUGIE REGROUPÉ (UN seul, directionnel) ----------
rng = high - low
atLow  = low  <= ta.lowest(low,  candleCtx)
atHigh = high >= ta.highest(high, candleCtx)
rangeOK = rng >= atr * rangeATR
cVolOK = not candleVol or volume > ta.sma(volume, volLen) * volMult
closeUp = rng > 0 and (close - low) / rng >= closePos
closeDn = rng > 0 and (high - close) / rng >= closePos
rsiBuyOK  = not candleRsi or r <= osLvl
rsiSellOK = not candleRsi or r >= obLvl
candleBull = useCandle and confirmed and atLow and rangeOK and cVolOK and closeUp and rsiBuyOK
candleBear = useCandle and confirmed and atHigh and rangeOK and cVolOK and closeDn and rsiSellOK
plotshape(candleBull, title="Signal bougie HAUSSIER", style=shape.labelup,   location=location.belowbar, color=color.new(#089981, 0), text="▲", textcolor=color.white, size=size.small)
plotshape(candleBear, title="Signal bougie BAISSIER", style=shape.labeldown, location=location.abovebar, color=color.new(#f23645, 0), text="▼", textcolor=color.white, size=size.small)

// ------------------------------- TABLEAU -------------------------------------
candleState = candleBull ? "HAUSSIER ▲" : candleBear ? "BAISSIER ▼" : "—"
candleCol   = candleBull ? color.green : candleBear ? color.red : color.gray
bias = bullDrives > bearDrives ? "Haussier" : bearDrives > bullDrives ? "Baissier" : "Neutre"
bcol = bullDrives > bearDrives ? color.green : bearDrives > bullDrives ? color.red : color.gray
rcol = r >= obLvl ? color.red : r <= osLvl ? color.green : color.white
var table t = table.new(position.top_right, 2, 4, border_width=1, frame_color=color.new(color.gray, 50), frame_width=1)
tShow = showPanel and barstate.islast
table.cell(t, 0, 0, tShow ? "RSI" : "", text_color=color.white, bgcolor=tShow ? color.new(color.gray, 30) : color.new(color.gray, 100))
table.cell(t, 1, 0, tShow ? str.tostring(r, "0") : "", text_color=rcol)
table.cell(t, 0, 1, tShow ? "Poussées ▲ / ▼" : "", text_color=color.white)
table.cell(t, 1, 1, tShow ? str.tostring(bullDrives) + " / " + str.tostring(bearDrives) : "", text_color=color.white)
table.cell(t, 0, 2, tShow ? "Biais divergence" : "", text_color=color.white)
table.cell(t, 1, 2, tShow ? bias : "", text_color=color.white, bgcolor=tShow ? color.new(bcol, 40) : color.new(color.gray, 100))
table.cell(t, 0, 3, tShow ? "Signal bougie" : "", text_color=color.white)
table.cell(t, 1, 3, tShow ? candleState : "", text_color=color.white, bgcolor=tShow ? color.new(candleCol, 40) : color.new(color.gray, 100))

// -------------------------------- ALERTES ------------------------------------
alertcondition(tripleBuy,   "Triple divergence BUY",  "TRIPLE divergence haussiere confirmee")
alertcondition(tripleSell,  "Triple divergence SELL", "TRIPLE divergence baissiere confirmee")
alertcondition(candleBull,  "Signal bougie HAUSSIER", "Bougie : retournement haussier confirme")
alertcondition(candleBear,  "Signal bougie BAISSIER", "Bougie : retournement baissier confirme")

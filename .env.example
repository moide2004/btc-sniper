# Copiez ce fichier en .env puis remplissez vos valeurs.
# Le .env est prive : il n'est JAMAIS envoye sur GitHub (.gitignore).

# ==========================================================================
#  BOT D'ALERTES BTC SNIPER (btc_sniper.py)
# ==========================================================================
# Token du bot Telegram (cree via @BotFather)
TELEGRAM_TOKEN=
# Id du chat destinataire des alertes
TELEGRAM_CHATID=
# Optionnel (valeurs par defaut indiquees)
# SYMBOL=BTCUSDT
# SCAN_INTERVAL=14400
# MIN_SCORE=82
# MIN_RR=3.0
# RISK_PCT=3.0

# ==========================================================================
#  TABLEAU DE BORD PORTEFEUILLE (dashboard.py)
# ==========================================================================
# Mot de passe pour acceder a la page web (CHOISIS-EN UN SOLIDE)
DASHBOARD_PASSWORD=
# Cle secrete pour les sessions (genere une valeur aleatoire, ex. :
#   python3 -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=

# --- Exchanges : CLES API EN LECTURE SEULE UNIQUEMENT ---
# (dans les reglages de l'exchange : cocher "lecture", JAMAIS "trading"/"retrait")
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSWORD=
# Autres exchanges optionnels :
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
# BYBIT_API_KEY=
# BYBIT_API_SECRET=

# --- Wallets : ADRESSES PUBLIQUES UNIQUEMENT ---
# JAMAIS la phrase secrete (12/24 mots) ni la cle privee !
# Plusieurs adresses possibles, separees par des virgules.
EVM_ADDRESSES=
SOLANA_ADDRESSES=

# Optionnel : points d'acces blockchain et devise
# EVM_RPC_URL=https://eth.llamarpc.com

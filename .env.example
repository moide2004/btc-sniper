# Copiez ce fichier en .env puis remplissez vos valeurs.
# Chargez-le avant de lancer le bot, par exemple :
#   set -a; source .env; set +a; python3 btc_sniper.py

# Obligatoire : token du bot Telegram (cree via @BotFather)
TELEGRAM_TOKEN=

# Obligatoire : id du chat destinataire des alertes
TELEGRAM_CHATID=

# Optionnel : surcharges de configuration (valeurs par defaut indiquees)
# SYMBOL=BTCUSDT
# SCAN_INTERVAL=14400
# MIN_SCORE=82
# MIN_RR=3.0
# RISK_PCT=3.0
